# =============================================================================
# NoobScribe — example environment (copy to .env)
# =============================================================================
# Docker Compose reads `.env` from the project root automatically. Copy this file:
#   cp env.example .env
# Then edit values. Never commit `.env` (it is gitignored).
#
# For Traefik deployment, see docker-compose.traefik.yaml and DOCKER_README.md.
# =============================================================================

# --- Docker image (docker-compose.yml + docker-compose.traefik.yaml) ------------
# Default is the upstream GHCR image. Override for your fork or a pinned tag, e.g. :main-abc1234
# NOOBSCRIBE_IMAGE=ghcr.io/meganoob1337/noobscribe:latest

# --- Traefik stack (docker-compose.traefik.yaml) --------------------------------
# Public hostname Traefik should match (no https://). Becomes Host(`...`) in labels.
# Example: api.example.com  or  noobscribe.home.arpa
NOOBSCRIBE_HOST=noobscribe.localhost

# Existing Docker network your Traefik container is attached to (external: true).
# Create if needed: docker network create traefik-global-proxy
TRAEFIK_NETWORK=traefik-global-proxy

# Traefik static config: entrypoint name for HTTPS (common: websecure, https).
TRAEFIK_ENTRYPOINT=websecure

# Traefik static config: certificate resolver name (e.g. letsencrypt, cloudflare).
TRAEFIK_CERT_RESOLVER=letsencrypt

# Host:container port publish (e.g. 8000:8000 or 127.0.0.1:8000:8000). Traefik does not need this
# for routing; useful for local debugging alongside the proxy.
NOOBSCRIBE_PUBLISH_PORT=8000:8000

# NVIDIA GPU index for the Traefik compose file (device_ids). Use 0 for first GPU, 1 for second, etc.
GPU_DEVICE_ID=0

# --- Hugging Face / diarization ------------------------------------------------
# Used by both compose files (mapped to HUGGINGFACE_ACCESS_TOKEN in the container).
# Required for pyannote/speaker-diarization-3.1 unless DIARIZATION_MODEL_PATH is set.
# HUGGINGFACE_TOKEN=hf_xxxxxxxx

# --- ASR / processing (optional overrides) ------------------------------------
# MODEL_ID=nvidia/canary-1b-v2
# MODEL_PATH=
# DIARIZATION_MODEL_PATH=
# CHUNK_DURATION=10
# TEMPERATURE=0.0
# DEBUG=0
# ENABLE_DIARIZATION=true
# INCLUDE_DIARIZATION_IN_TEXT=true

# --- Local dev / non-Docker (see README) --------------------------------------
# HUGGINGFACE_ACCESS_TOKEN=hf_xxxxxxxx
# DATABASE_URL=sqlite+aiosqlite:///./data/noobscribe.db
# CHROMADB_PATH=./data/speakers
# RECORDINGS_PATH=./data/recordings
# TEMP_DIR=/tmp/noobscribe
# SPEAKER_SIMILARITY_THRESHOLD=0.7
